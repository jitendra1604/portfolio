# Copy to .env.local and fill in. All values are optional in dev.

# Public site URL — used for metadata, OpenGraph, robots.txt and sitemap.xml.
# Set this to your real domain in production (e.g. https://jeet.dev).
NEXT_PUBLIC_SITE_URL=http://localhost:3004

# --- Contact form email (SMTP via Nodemailer) -------------------------------
# Without these, the contact form validates and logs only (no email sent).
# Gmail example: create an App Password (Google Account → Security →
# 2-Step Verification → App passwords) and use it as SMTP_PASS.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your-address@gmail.com
SMTP_PASS=your-16-char-app-password
# Where contact messages are delivered (defaults to SMTP_USER if unset).
CONTACT_TO=jeet@zyptr.com

# --- AI chatbot (optional) --------------------------------------------------
# Without a key the chatbot falls back to keyword search over the portfolio
# content. With a key it streams answers from OpenAI.
OPENAI_API_KEY=
# Chat model (defaults to gpt-4.1-mini if unset)
OPENAI_CHAT_MODEL=gpt-4.1-mini
# Embedding model for semantic search (defaults to text-embedding-3-small)
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
